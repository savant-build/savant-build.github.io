#!/usr/bin/env bash

REPO="savant-build/savant-core"
INSTALL_BASE="${XDG_DATA_HOME:-$HOME/.local/share}/savant/versions"
BIN_DIR="$HOME/.local/bin"

info() { printf '\033[1;94m%s\033[0m\n' "$*"; }
error() { printf '\033[1;91mError: %s\033[0m\n' "$*" >&2; exit 1; }

# Check dependencies
for cmd in curl tar; do
  command -v "$cmd" >/dev/null 2>&1 || error "$cmd is required but not installed."
done

# Determine latest version from GitHub
info "Fetching latest Savant release..."
VERSION=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" 2> /dev/null \
  | grep '"tag_name"' \
  | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/')

[ -n "$VERSION" ] || error "Could not determine latest version."
info "Latest version: $VERSION"

INSTALL_DIR="${INSTALL_BASE}/${VERSION}"

# Skip download if already installed
if [ -d "$INSTALL_DIR" ] && [ -x "$INSTALL_DIR/bin/sb" ]; then
  info "Savant $VERSION is already installed at $INSTALL_DIR"
else
  TARBALL_URL="https://github.com/${REPO}/releases/download/${VERSION}/savant-${VERSION}.tar.gz"

  info "Downloading savant-${VERSION}.tar.gz..."
  TMPDIR=$(mktemp -d)
  trap 'rm -rf "$TMPDIR"' EXIT

  curl -fsSL "$TARBALL_URL" -o "$TMPDIR/savant.tar.gz" \
    || error "Download failed. Check that version $VERSION exists."

  info "Installing to $INSTALL_DIR..."
  mkdir -p "$INSTALL_BASE"
  tar xzf "$TMPDIR/savant.tar.gz" -C "$INSTALL_BASE"

  # The tarball extracts to savant-{version}/, rename to just {version}/
  if [ -d "${INSTALL_BASE}/savant-${VERSION}" ]; then
    mv "${INSTALL_BASE}/savant-${VERSION}" "$INSTALL_DIR"
  fi

  [ -x "$INSTALL_DIR/bin/sb" ] || chmod +x "$INSTALL_DIR/bin/sb"
fi

# Symlink sb to ~/.local/bin
mkdir -p "$BIN_DIR"
ln -sf "$INSTALL_DIR/bin/sb" "$BIN_DIR/sb"
info "Linked sb → $BIN_DIR/sb"

# Check if ~/.local/bin is in PATH
case ":$PATH:" in
  *":$BIN_DIR:"*) ;;
  *)
    info ""
    info "Add $BIN_DIR to your PATH. For example:"
    info "  echo 'export PATH=\"\$HOME/.local/bin:\$PATH\"' >> ~/.bashrc"
    ;;
esac

info ""
info "Savant $VERSION installed successfully! Run 'sb' to get started."
