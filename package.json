{
  "name": "savant-build-website",
  "private": true,
  "scripts": {
    "build:css": "postcss css/main.css -o css/styles.css",
    "watch:css": "postcss css/main.css -o css/styles.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"bundle exec jekyll serve --livereload\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4",
    "concurrently": "^9.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4"
  }
}
